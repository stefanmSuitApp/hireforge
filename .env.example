# Optional for local shells; do not rely on this for `next build` (Nx web:build forces NODE_ENV=production).
# NODE_ENV=development

# Apps (local): web :3000 → NEXT_PUBLIC_API_URL | api :4000 (Nest) | cms :4200 (Vite) | worker (BullMQ + Redis)
# Infra: docker-compose Postgres + Redis; api/worker load repo-root `.env` via load-root-env (path walk, not cwd).

# Caddy / TLS (production deploy only)
# ACME_EMAIL=ops@example.com

# Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Nest API origin only (port 4000) — not the Next app (3000). Omit trailing path or use .../api if you prefer; both work.
NEXT_PUBLIC_API_URL=http://localhost:4000
# Optional: URL the **Next server** uses to call Nest (RSC + BFF). Use when Next runs in Docker and `localhost` is wrong (e.g. http://host.docker.internal:4000 or http://api:4000).
NEST_API_URL=http://localhost:4000
NEXT_PUBLIC_DEFAULT_LOCALE=sr
NEXT_PUBLIC_SUPPORTED_LOCALES=sr,en

# --- Docker Compose: Postgres + Redis (see docker-compose.yml) ---
# Copy to `.env` and run: pnpm docker:up
# Host ports: 5434 (Postgres), 6382 (Redis). Change passwords before any shared network.

POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_USER=hireforge
POSTGRES_PASSWORD=hireforge_dev_pg
POSTGRES_DB=hireforge

# URL-encode special characters in the password (e.g. @ → %40).
DATABASE_URL=postgresql://hireforge:hireforge_dev_pg@localhost:5434/hireforge

REDIS_HOST=localhost
REDIS_PORT=6382
REDIS_PASSWORD=hireforge_dev_redis

# Format: redis://:PASSWORD@HOST:PORT  (password must be URL-encoded if it contains @ # : / etc.)
REDIS_URL=redis://:hireforge_dev_redis@localhost:6382

# API
API_PORT=4000
BULLMQ_PREFIX={hireforge}
# Worker: poll `outbox_events` and enqueue BullMQ `outbox-dispatch` jobs.
OUTBOX_POLL_INTERVAL_MS=3000
OUTBOX_POLL_BATCH=50
# Worker: BullMQ job scheduler interval for `scheduled-tick` (ms). Set to 0 to disable.
WORKER_SCHEDULE_TICK_MS=900000
# Worker: interval for `cms-packages-reconcile` (ms). Default 86400000 (24h). Set to 0 to disable.
WORKER_CMS_PACKAGES_RECONCILE_MS=86400000
# Worker: NBS EUR/RSD middle-rate refresh → Redis (ms). Default 86400000 (24h). Set to 0 to disable.
WORKER_NBS_MIDDLE_RATE_MS=86400000

# Candidate CV files on disk (defaults to ./var/candidate-uploads under API cwd). Use an absolute path in production.
CANDIDATE_UPLOAD_DIR=var/candidate-uploads

# Dev auth: set to 1 and send header `X-Hireforge-Dev-User-Id` with a seeded user uuid (see scripts/db/seed-domain-baseline.sql)
AUTH_DEV_HEADERS=0

# JWT signing for employer login (HS256). Use a long random string (32+ chars). Required in production.
AUTH_JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# Optional: comma-separated hostname rules for employer "external apply" URLs (Step 10.2). When set, the URL host must equal or end with one rule (e.g. careers.example.com,myats.com).
EXTERNAL_APPLY_HOST_ALLOWLIST=

# Employer job description rich-text links (Step 11.5): comma-separated hostname rules; host must not equal or be a subdomain of a listed entry (e.g. bit.ly,tinyurl.com).
EDITOR_LINK_HOST_BLOCKLIST=
# Minimum plain-text characters before the first https link (anti-spam). Set to 0 to disable.
EDITOR_LINK_MIN_PLAIN_CHARS_BEFORE_FIRST=50

# Job description inlined images — Step 11.6 (`POST …/jobs/:id/image`, AVIF blobs). Upload JSON `url` defaults to `/api/public/job-description-media/:id` (Next proxies to Nest) so previews load same-origin as the web app. Set `JOB_DESCRIPTION_MEDIA_PUBLIC_ORIGIN` only when you need an absolute CDN/API hostname instead.
# Local default: `./var/job-description-media` under API cwd. For S3, set bucket + reuse `S3_ENDPOINT`, `AWS_ACCESS_KEY_ID`, `AWS_SECRET_ACCESS_KEY`, `S3_REGION`, optional `S3_FORCE_PATH_STYLE`.
JOB_DESCRIPTION_MEDIA_PUBLIC_ORIGIN=
JOB_DESCRIPTION_MEDIA_LOCAL_DIR=var/job-description-media
S3_JOB_MEDIA_BUCKET=

# CMS / Sanity (API integration check uses NEXT_PUBLIC_* or overrides below)
NEXT_PUBLIC_SANITY_PROJECT_ID=845zdl9k
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_PROJECT_ID=845zdl9k
SANITY_DATASET=production
SANITY_API_READ_TOKEN=
# Write token for `pnpm cms:seed` (Content API write scope).
SANITY_API_WRITE_TOKEN=
SANITY_WEBHOOK_SECRET=
# Shared secret for `POST /api/cms/sync/package` (header `x-cms-sync-secret`).
CMS_SYNC_SECRET=
# Sanity Studio (`apps/cms`, `pnpm dev:cms`) — required for Studio startup; Nx loads repo-root `.env` via `envFile`
SANITY_STUDIO_PROJECT_ID=845zdl9k
SANITY_STUDIO_DATASET=production

# Optional: pnpm integration:check (defaults to NEXT_PUBLIC_API_URL)
INTEGRATION_API_URL=http://localhost:4000

# Billing (Step 9): `1` prefixes document numbers with TEST- and watermarks PDFs; when set, outbound billing email may route to BILLING_EMAIL_TEST_TO.
BILLING_TEST_MODE=0

# Proforma/invoice PDF storage — default: local directory under API cwd.
BILLING_PDF_LOCAL_DIR=var/billing-pdfs

# Production: S3-compatible bucket (Hetzner Object Storage recommended with Hetzner VMs).
# Endpoint examples: https://fsn1.your-objectstorage.com | https://nbg1.your-objectstorage.com | https://hel1.your-objectstorage.com
# Match S3_REGION to the location id (e.g. fsn1) when Hetzner docs specify it; eu-central-1 also works for many setups.
S3_BILLING_BUCKET=
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# MinIO / some compat servers: S3_FORCE_PATH_STYLE=true
S3_FORCE_PATH_STYLE=false

# Wire / refund fallbacks when Sanity is empty (see BillingContentService)
BILLING_IBAN=
BILLING_SWIFT_BIC=
BILLING_WIRE_ACCOUNT_HOLDER_SR=
BILLING_WIRE_BANK_SR=
BILLING_REFUND_EXCERPT_SR=

# Worker: transactional billing email (optional). Without RESEND_API_KEY, outbox still processes; only billing_email_* logs appear when key is set.
# RESEND_API_KEY=
# EMAIL_FROM_ADDRESS=noreply@sljakam.com
# EMAIL_FROM_NAME=Šljakam
# Absolute origin for links in billing emails (e.g. https://sljakam.com). Falls back to NEXT_PUBLIC_APP_URL.
# BILLING_EMAIL_DASHBOARD_ORIGIN=https://sljakam.com
# When BILLING_TEST_MODE=1, send all billing messages here instead of the employer address.
BILLING_EMAIL_TEST_TO=

