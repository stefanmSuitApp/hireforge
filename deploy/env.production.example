# Copy to deploy/.env.production on the server and replace every placeholder.
# Never commit deploy/.env.production.

# Caddy / TLS
ACME_EMAIL=ops@example.com

# Public web origin. The root domain is served by Next; Nest remains private.
NEXT_PUBLIC_APP_URL=https://sljakam.com
NEXT_PUBLIC_API_URL=http://api:4000
NEST_API_URL=http://api:4000
NEXT_PUBLIC_DEFAULT_LOCALE=sr
NEXT_PUBLIC_SUPPORTED_LOCALES=sr,en

# Postgres container
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=hireforge
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
POSTGRES_DB=hireforge
DATABASE_URL=postgresql://hireforge:replace-with-a-url-encoded-postgres-password@postgres:5432/hireforge

# Redis container
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-a-long-random-redis-password
REDIS_URL=redis://:replace-with-a-url-encoded-redis-password@redis:6379
BULLMQ_PREFIX={hireforge}

# API / auth
API_PORT=4000
AUTH_DEV_HEADERS=0
AUTH_JWT_SECRET=replace-with-a-long-random-jwt-secret-min-32-chars
EXTERNAL_APPLY_HOST_ALLOWLIST=
EDITOR_LINK_HOST_BLOCKLIST=bit.ly,tinyurl.com
EDITOR_LINK_MIN_PLAIN_CHARS_BEFORE_FIRST=50

# Worker
OUTBOX_POLL_INTERVAL_MS=3000
OUTBOX_POLL_BATCH=50
WORKER_SCHEDULE_TICK_MS=900000
WORKER_CMS_PACKAGES_RECONCILE_MS=86400000
WORKER_NBS_MIDDLE_RATE_MS=86400000

# Local fallback storage volumes. Prefer S3/Object Storage for billing PDFs.
CANDIDATE_UPLOAD_DIR=var/candidate-uploads
JOB_DESCRIPTION_MEDIA_LOCAL_DIR=var/job-description-media
BILLING_PDF_LOCAL_DIR=var/billing-pdfs

# Job description media public origin. Leave empty for same-origin Next proxy.
JOB_DESCRIPTION_MEDIA_PUBLIC_ORIGIN=
S3_JOB_MEDIA_BUCKET=

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=845zdl9k
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_PROJECT_ID=845zdl9k
SANITY_DATASET=production
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=
SANITY_WEBHOOK_SECRET=replace-with-a-long-random-sanity-webhook-secret
CMS_SYNC_SECRET=replace-with-a-long-random-cms-sync-secret
SANITY_STUDIO_PROJECT_ID=845zdl9k
SANITY_STUDIO_DATASET=production

# Billing PDF storage on Hetzner Object Storage (S3-compatible)
S3_BILLING_BUCKET=
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Billing copy / wire fallback values when Sanity content is absent
BILLING_TEST_MODE=0
BILLING_IBAN=
BILLING_SWIFT_BIC=
BILLING_WIRE_ACCOUNT_HOLDER_SR=
BILLING_WIRE_BANK_SR=
BILLING_REFUND_EXCERPT_SR=

# Transactional billing email
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@sljakam.com
EMAIL_FROM_NAME=Šljakam
BILLING_EMAIL_DASHBOARD_ORIGIN=https://sljakam.com
BILLING_EMAIL_TEST_TO=

# Integration smoke command default
INTEGRATION_API_URL=http://api:4000
