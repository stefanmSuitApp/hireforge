{
  "name": "hireforge",
  "version": "1.0.0",
  "description": "Modern hiring platform monorepo built with Nx, Next.js, and NestJS.",
  "private": true,
  "scripts": {
    "nx": "nx",
    "graph": "nx graph",
    "clean": "nx reset",
    "dev:web": "NX_DAEMON=false nx dev web",
    "dev:api": "NX_DAEMON=false nx serve api --skip-nx-cache",
    "dev:worker": "NX_DAEMON=false nx serve worker",
    "dev:cms": "NX_DAEMON=false nx dev cms",
    "dev:all": "nx reset --onlyWorkspaceData && concurrently -k -n web,api,worker,cms -c blue,green,yellow,magenta \"pnpm dev:web\" \"pnpm dev:api\" \"pnpm dev:worker\" \"pnpm dev:cms\"",
    "dev:all:fast": "concurrently -k -n web,api,worker,cms -c blue,green,yellow,magenta \"pnpm dev:web\" \"pnpm dev:api\" \"pnpm dev:worker\" \"pnpm dev:cms\"",
    "start:web": "NX_DAEMON=false nx start web",
    "build": "nx run-many -t build --all",
    "build:web": "nx build web",
    "analyze:web": "nx run web:analyze",
    "build:api": "nx build api",
    "build:worker": "nx build worker",
    "build:cms": "nx build cms",
    "lint": "nx run-many -t lint --all",
    "lint:web": "nx lint web",
    "lint:api": "nx lint api",
    "lint:worker": "nx lint worker",
    "lint:cms": "nx lint cms",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "nx run-many -t typecheck --all",
    "test": "nx run-many -t test --all --exclude=api,worker",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "node scripts/db/migrate.mjs",
    "db:studio": "drizzle-kit studio",
    "db:seed": "pnpm run db:seed:all",
    "db:seed:all": "pnpm run db:seed:rs && pnpm run db:seed:domain",
    "db:seed:rs": "node scripts/db/seed-rs-locations.mjs",
    "db:seed:domain": "node scripts/db/seed-domain-baseline.mjs",
    "cms:seed": "node scripts/cms/seed-sanity.mjs",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "integration:check": "node scripts/integration/check.mjs"
  },
  "keywords": [],
  "author": "Šljakam",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.28.0",
